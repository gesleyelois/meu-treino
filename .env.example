# Replace with your actual Neon connection string
DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require"

# Neon Auth Configuration
NEON_AUTH_BASE_URL="https://your-branch.neonauth.us-east-1.aws.neon.tech/neondb/auth"
NEON_AUTH_COOKIE_SECRET="a-very-secure-random-secret-key-that-is-at-least-thirty-two-chars"

# Vercel Blob Storage (required for file uploads)
# Get this from: Vercel Dashboard > Project > Storage > Create Blob Store
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
